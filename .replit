entrypoint = "README.md"
modules = ["nodejs-22"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "npx expo export --platform web && npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist"]
run = ["bash", "-c", "NODE_ENV=production node server_dist/index.js"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3002

[env]
PORT = "5000"

[agent]
stack = "EXPO"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Deprecated - use Project workflow'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-metro.sh"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Sync & Build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/sync-build.sh"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

