# TopRanker Environment Variables
# Required
DATABASE_URL=postgresql://user:password@localhost:5432/topranker
SESSION_SECRET=your-secret-here

# Google Maps (for map view and place photos)
GOOGLE_API_KEY=your-google-api-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Optional
# STRIPE_SECRET_KEY=sk_test_...
# RESEND_API_KEY=re_...
# PORT=5000
# NODE_ENV=development

# Railway (auto-set by Railway platform)
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# File storage (Cloudflare R2 for avatar uploads in production)
# R2_BUCKET_NAME=topranker-uploads
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_PUBLIC_URL=https://your-bucket.r2.dev
